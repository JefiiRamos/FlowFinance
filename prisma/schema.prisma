datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String?
  createdAt     DateTime  @default(now())
  sessions      Session[]
  transactions  Transaction[]
  recurringIncomes RecurringIncome[]
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  date        DateTime
  description String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model RecurringIncome {
  id          String  @id @default(uuid())
  dayOfMonth  Int
  amount      Float
  startMonth  Int
  endMonth    Int
  description String  @default("Renda fixa")
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}